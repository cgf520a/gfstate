{
  "compilerOptions": {
    "target": "ES2015",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "baseUrl": "./",
    "paths": {
      "@@/*": [".dumi/tmp/*"]
    },
    "types": ["jest", "node", "@testing-library/jest-dom", "react", "react-dom"]
  },
  "include": [".dumirc.ts", "src/**/*"]
}
